# Grilla de campo
GRID_RESOLUTION = 20          # Puntos por eje (20 = grilla 20x20x20)
GRID_BOUNDS = (-1.0, 1.0,    # x_min, x_max en metros
               -1.0, 1.0,    # y_min, y_max en metros
               -1.0, 1.0)    # z_min, z_max en metros

